package Helper_Package;

import java.io.File;
import java.io.FileInputStream;
import java.io.IOException;
import java.net.URL;
import java.util.Properties;

public class Configiration_reder {
	
	public static Properties p;

	public Configiration_reder() throws IOException {
		
	File config = new File("C:\\Users\\ragum\\eclipse-workspace\\Admin_Panel\\src\\test\\java\\Dot_Properties\\Data_Property");
	
	FileInputStream fis = new FileInputStream(config);
	
	p = new Properties();
	
	p.load(fis);
	
	}
	
	public String Base_url() {
		String property = p.getProperty("Application_Url");
		return property;
		
	} 
	public String  getUsername() {
		
		String property = p.getProperty("Email");
		return property;
	}
	public String pass() {
		String property = p.getProperty("Pass");
		return property;
	}
	
}
