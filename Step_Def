package com.Step_Definition;

import java.io.IOException;

import com.Base_Class.Base_Class;
import com.Pom_Class.Pom_Class;

import Helper_Package.File_reader;
import io.cucumber.java.en.Given;
import io.cucumber.java.en.Then;
import io.cucumber.java.en.When;

public class Step_Definition extends Base_Class {
	
	
	Pom_Class ap = new Pom_Class(driver);
	
	//Login
	
	@Given("that the Admin launches the application")
	public void that_the_admin_launches_the_application() throws IOException {
		//getUrl("https://admin.yesmechanic.co/login");
		
		String base_url = File_reader.getInstance().getInstanceAR().Base_url();
		
		driver.get(base_url);
	}
	@When("the Admin enters a valid {string} in the email field")
	public void the_admin_enters_a_valid_in_the_email_field(String Email) throws IOException {
		clearField(ap.getEmailid());
		//SendKeys(ap.getEmailid(), Email);
		
		String username = File_reader.getInstance().getInstanceAR().getUsername();
		SendKeys(ap.getEmailid(), username);
		
	}
	@When("the Admin enters a valid {string} in the password field")
	public void the_admin_enters_a_valid_in_the_password_field(String Password) throws IOException {
		clearField(ap.getPassword());
		//SendKeys(ap.getPassword(), Password);
		
		String pass = File_reader.getInstance().getInstanceAR().pass();
		SendKeys(ap.getPassword(), pass);

	}
	@Then("the Admin clicks the login button and navigates to the dashboard page {string}")
	public void the_admin_clicks_the_login_button_and_navigates_to_the_dashboard_page(String string) throws InterruptedException {
		Thread.sleep(5000);
		Actions(ap.getLoginbutton());
	    
	}
